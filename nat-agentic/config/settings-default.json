{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(bun *)",
      "Bash(node *)",
      "Bash(nat *)",
      "Glob(**)",
      "Grep(**)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(sudo rm *)",
      "Bash(format *)",
      "Bash(mkfs *)"
    ]
  },

  "plugin-dir": [
    "${NAT_AGENTIC_HOME}/marketplace/plugins/nat-core",
    "${NAT_AGENTIC_HOME}/marketplace/plugins/nat-git-workflow",
    "${NAT_AGENTIC_HOME}/marketplace/plugins/nat-security",
    "${NAT_AGENTIC_HOME}/marketplace/plugins/nat-code-quality"
  ]
}
