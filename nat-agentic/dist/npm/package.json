{
  "name": "@nat-agentic/cli",
  "version": "1.0.0",
  "description": "Nat Agentic - Custom Claude Code Distribution with Curated Plugins",
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "cli",
    "code-assistant",
    "developer-tools"
  ],
  "author": "Nat Agentic Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nat-agentic/nat-agentic.git"
  },
  "bugs": {
    "url": "https://github.com/nat-agentic/nat-agentic/issues"
  },
  "homepage": "https://nat-agentic.dev",
  "bin": {
