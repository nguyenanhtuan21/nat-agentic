{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit(**)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/security-check.py --file \"$CLAUDE_FILE_PATH\" --content \"$CLAUDE_NEW_CONTENT\""
          }
        ]
      },
      {
        "matcher": "Write(**)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/security-check.py --file \"$CLAUDE_FILE_PATH\" --content \"$CLAUDE_CONTENT\""
          }
        ]
      }
    ]
  }
}
